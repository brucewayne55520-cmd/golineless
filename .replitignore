# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# No need to store the pnpm store twice.
.local

# Git history — not needed in deployed images or downloads
.git

# Dependencies are installed fresh at build time
node_modules
artifacts/api-server/node_modules
artifacts/qbuddy/node_modules
artifacts/mockup-sandbox/node_modules

# Build artefacts regenerated at build time
dist
*.tsbuildinfo
